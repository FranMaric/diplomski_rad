<?xml version="1.0" ?>
<launch>

  <arg name="robot" default="panda" doc="choose your robot. Possible values: [panda, fr3]"/>
  <arg name="arm_id" default="$(arg robot)" />

  <!-- simulation toggle -->
  <arg name="sim" default="false"/>

  <!-- Gazebo ONLY if sim=true -->
  <include file="$(find franka_gazebo)/launch/panda.launch"
           if="$(arg sim)">
    <arg name="x" value="-0.5"/>
    <arg name="world" value="$(find franka_gazebo)/world/stone.sdf"/>
    <arg name="rviz" value="true"/>
  </include>

  <!-- Runs ONLY if sim=false -->
  <include file="$(find franka_control)/launch/franka_control.launch" 
            pass_all_args="true"
            unless="$(arg sim)"/>

    <!-- Set end effector payload for gravity/Coriolis compensation and for EE frame use TCP frame-->
  <node name="set_ee_load" pkg="my_custom_launcher" type="set_ee_load.py"/>

  <!-- REAL ROBOT controllers -->
  <rosparam command="load"
      file="$(find franka_example_controllers)/config/franka_example_controllers.yaml"
      subst_value="true"
      unless="$(arg sim)"/>

  <!-- SIMULATION controllers -->
  <rosparam command="load"
      file="$(find franka_gazebo)/config/sim_controllers.yaml"
      subst_value="true"
      if="$(arg sim)"/>

  <node name="controller_spawner"
        pkg="controller_manager"
        type="spawner"
        respawn="false"
        output="screen"
        args="cartesian_impedance_example_controller"/> <!-- cartesian_impedance_example_controller / position_joint_trajectory_controller -->

  <!-- TCP static transform: panda_link8 → tcp (flange to dremel tip) -->
  <!-- Translation and rotation computed from publish_tcp_transform() in robot_control.py -->
  <!-- tx=sin(pi/4)*0.19, ty=-sin(pi/4)*0.19, tz=0.113 | rpy=[pi, 0, -3*pi/4] -->
  <node pkg="tf2_ros"
        type="static_transform_publisher"
        name="tcp_transform_publisher"
        args="0.13435 -0.13435 0.113  0.382683 -0.923880 0.0 0.0  panda_link8 tcp"/>

  <node name="set_compliance_params" pkg="my_custom_launcher" type="set_compliance_params.py" output="screen"/>

  <node pkg="rviz"
        type="rviz"
        output="screen"
        name="rviz"
        unless="$(arg sim)"
        args="-d $(find franka_example_controllers)/launch/rviz/franka_description_with_marker.rviz
              -f $(arg arm_id)_link0
              --splash-screen $(find franka_visualization)/splash.png"/>

</launch>