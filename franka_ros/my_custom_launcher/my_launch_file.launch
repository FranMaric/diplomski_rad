<?xml version="1.0" ?>
<launch>

  <arg name="robot" default="panda" doc="choose your robot. Possible values: [panda, fr3]"/>
  <arg name="arm_id" default="$(arg robot)" />

  <!-- simulation toggle -->
  <arg name="sim" default="false"/>

  <!-- Gazebo ONLY if sim=true -->
  <include file="$(find franka_gazebo)/launch/panda.launch"
           if="$(arg sim)">
    <arg name="x" value="-0.5"/>
    <arg name="world" value="$(find franka_gazebo)/world/stone.sdf"/>
    <arg name="rviz" value="true"/>
  </include>

  <!-- Runs ONLY if sim=false -->
  <include file="$(find franka_control)/launch/franka_control.launch" 
            pass_all_args="true"
            unless="$(arg sim)"/>

    <!-- Set end effector payload for gravity/Coriolis compensation and for EE frame use TCP frame-->
  <node name="set_ee_load" pkg="my_custom_launcher" type="set_ee_load.py"/>

  <!-- REAL ROBOT controllers -->
  <rosparam command="load"
      file="$(find serl_franka_controllers)/config/serl_franka_controllers.yaml"
      subst_value="true"
      unless="$(arg sim)"/>

  <!-- SIMULATION controllers -->
  <rosparam command="load"
      file="$(find franka_gazebo)/config/sim_controllers.yaml"
      subst_value="true"
      if="$(arg sim)"/>

  <node name="controller_spawner"
        pkg="controller_manager"
        type="spawner"
        respawn="false"
        output="screen"
        args="cartesian_impedance_controller"/> <!-- serl: cartesian_impedance_controller / joint_position_controller -->

  <node name="set_compliance_params" pkg="my_custom_launcher" type="set_compliance_params.py" output="screen"/>

  <node pkg="rviz"
        type="rviz"
        output="screen"
        name="rviz"
        unless="$(arg sim)"
        args="-d $(find my_custom_launcher)/rviz/franka_with_actions.rviz
              -f $(arg arm_id)_link0
              --splash-screen $(find franka_visualization)/splash.png"/>

</launch>